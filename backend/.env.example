# MySQL no EasyPanel
#
# Dentro do EasyPanel (backend deployado):
# DATABASE_URL="mysql://mysql:SENHA@auto_eventhub:3306/eventhub-db"
#
# Do seu PC (MySQL exposto na aba "Expor"):
# DATABASE_URL="mysql://mysql:SENHA@HOST_PUBLICO:3306/eventhub-db"

DATABASE_URL=""

JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-por-outro-segredo-forte"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://127.0.0.1:3000,http://localhost:3000"
