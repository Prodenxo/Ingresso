# MySQL no EasyPanel
#
# Dentro do EasyPanel (backend deployado):
# DATABASE_URL="mysql://mysql:SENHA@auto_eventhub:3306/eventhub-db"
#
# Do seu PC (MySQL exposto na aba "Expor"):
# DATABASE_URL="mysql://mysql:SENHA@HOST_PUBLICO:3306/eventhub-db"

DATABASE_URL=""

JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-por-outro-segredo-forte"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://127.0.0.1:3000,http://localhost:3000"
# URL pública do frontend (EasyPanel) — também aceita via FRONTEND_URL
FRONTEND_URL="https://auto-eventhub-frontend.4tnf3f.easypanel.host"
FLYER_MAX_MB=15

# EasyPanel: monte um volume persistente em /app/uploads no serviço do backend.
# Sem volume, os flyers somem a cada redeploy do container.

# Chave para criptografar credenciais de gateway (Inter, etc.) — mínimo 32 caracteres
PAYMENTS_ENCRYPTION_KEY="troque-por-uma-chave-forte-com-32-caracteres-ou-mais"
